# Copy to `.env.local` and fill with your Firebase Web App config.
# Only VITE_* vars reach the client; these Firebase keys are public by design.

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Calendar sync (Phase 4) ---
# Set to the deployed Vercel URL (no trailing slash) so the "Add to Calendar"
# button opens the webcal:// subscription instead of downloading the .ics file.
# Leave empty in local dev — the button will download the .ics as a fallback.
VITE_APP_URL=

# CI secrets (GitHub Actions, not here): FIREBASE_SERVICE_ACCOUNT, FOOTBALL_DATA_TOKEN
