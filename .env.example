# Copy to `.env.local` and fill with your Firebase Web App config.
# Only VITE_* vars reach the client; these Firebase keys are public by design.

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Google OAuth / Calendar (Phase 4) ---
VITE_GOOGLE_OAUTH_CLIENT_ID=

# CI secrets (GitHub Actions, not here): FIREBASE_SERVICE_ACCOUNT, FOOTBALL_DATA_TOKEN
